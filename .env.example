# =============================================================================
# Application
# =============================================================================
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
INSTANCE_ID=instance-1

# =============================================================================
# Security
# =============================================================================
JWT_SECRET_KEY=change-me-to-a-64-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# =============================================================================
# PostgreSQL
# =============================================================================
DATABASE_URL=postgresql+asyncpg://gameuser:gamepass@localhost:5432/gamedb
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# Game Configuration
# =============================================================================
GAME_TICK_RATE_MS=50
MATCHMAKING_INTERVAL_MS=500
ELO_INITIAL=1000
ELO_TOLERANCE_BASE=100
ELO_TOLERANCE_EXPANSION_PER_SEC=10
ELO_TOLERANCE_MAX=500
MAX_MATCHMAKING_WAIT_SEC=120

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WS_MESSAGES_PER_SEC=30
RATE_LIMIT_REST_REQUESTS_PER_MIN=60

# =============================================================================
# Session
# =============================================================================
SESSION_TTL_SEC=3600
RECONNECT_GRACE_PERIOD_SEC=30
HEARTBEAT_INTERVAL_SEC=10
HEARTBEAT_TIMEOUT_SEC=30

# =============================================================================
# State Snapshots
# =============================================================================
STATE_SNAPSHOT_INTERVAL_SEC=2
INSTANCE_HEARTBEAT_INTERVAL_SEC=5
INSTANCE_HEARTBEAT_TTL_SEC=15
